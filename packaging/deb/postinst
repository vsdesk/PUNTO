#!/bin/sh
# postinst — udev + group "input" so the daemon can use /dev/input and /dev/uinput.
# Autostart uses "sg input" so the daemon gets the group even before the next login.

# Group "input" must exist before usermod (some minimal images omit it).
if ! getent group input >/dev/null 2>&1; then
    if ! groupadd --system input 2>/dev/null; then
        groupadd -r input 2>/dev/null || true
    fi
fi

case "$1" in
    configure|upgrade)
        if command -v udevadm >/dev/null 2>&1; then
            udevadm control --reload-rules 2>/dev/null || true
            udevadm trigger --subsystem-match=misc --name-match=uinput 2>/dev/null || true
        fi

        # Interactive logins (UID 1000+): include /home, /var/home, and any $HOME (NFS, custom paths).
        for u in $(getent passwd | awk -F: '$3>=1000 && $3<65534 && $6!="" && $7!="" && $7 !~ /(nologin|false)$/ {print $1}'); do
            if id -nG "$u" 2>/dev/null | tr ' ' '\n' | grep -qx input; then
                continue
            fi
            if usermod -aG input "$u" 2>/tmp/punto-usermod.err; then
                logger -t punto-switcher-postinst "added user $u to group input" || true
            else
                logger -t punto-switcher-postinst "usermod -aG input $u failed: $(cat /tmp/punto-usermod.err 2>/dev/null || true)" || true
            fi
        done
        rm -f /tmp/punto-usermod.err

        # Installing user when dpkg was invoked via sudo (often set in environment).
        if [ -n "${SUDO_USER:-}" ] && getent passwd "$SUDO_USER" >/dev/null 2>&1; then
            if ! id -nG "$SUDO_USER" 2>/dev/null | tr ' ' '\n' | grep -qx input; then
                if usermod -aG input "$SUDO_USER" 2>/tmp/punto-su.err; then
                    logger -t punto-switcher-postinst "added SUDO_USER=$SUDO_USER to group input" || true
                else
                    logger -t punto-switcher-postinst "usermod SUDO_USER failed: $(cat /tmp/punto-su.err 2>/dev/null || true)" || true
                fi
                rm -f /tmp/punto-su.err
            fi
        fi
        ;;
esac

#DEBHELPER#

exit 0
