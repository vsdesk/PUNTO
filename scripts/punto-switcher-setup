#!/bin/bash
# punto-switcher-setup
#
# Migrates the user's existing KDE keyboard layouts to Fcitx5 and configures
# KWin to use Fcitx5 as the virtual keyboard — making Punto Switcher functional.
#
# Safe by design:
#   - Backs up existing Fcitx5 configs before modifying them
#   - Detects current state and skips steps that are already done
#   - Never removes existing layouts; only adds missing ones
#   - Can be run multiple times (idempotent)
#
# Usage:
#   punto-switcher-setup                  # full setup
#   punto-switcher-setup --status       # show current state, no changes
#   punto-switcher-setup --sync-kde-keyboard  # re-apply KDE kxkbrc/shortcuts from Fcitx5
#   punto-switcher-setup --undo         # restore KDE native keyboard (remove Fcitx5 as VK)

set -eo pipefail

KXKBRC="${HOME}/.config/kxkbrc"
FCITX5_DIR="${HOME}/.config/fcitx5"
FCITX5_PROFILE="${FCITX5_DIR}/profile"
FCITX5_CONFIG="${FCITX5_DIR}/config"
KWINRC="${HOME}/.config/kwinrc"
AUTOSTART_DIR="${HOME}/.config/autostart"
AUTOSTART_ENTRY="${AUTOSTART_DIR}/punto-switcher-setup.desktop"
# Re-applies kxkbrc + kglobalshortcutsrc from Fcitx5 after Plasma overwrites them on login.
AUTOSTART_KDE_SYNC="${AUTOSTART_DIR}/punto-switcher-kde-sync.desktop"

# ─── Colours (ANSI bytes — must be $'…' or echo prints literal \033) ─────────
RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; RESET=$'\033[0m'
info()    { echo -e "${CYAN}[INFO]${RESET}  $*"; }
ok()      { echo -e "${GREEN}[OK]${RESET}    $*"; }
warn()    { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
err()     { echo -e "${RED}[ERROR]${RESET} $*" >&2; }

# ─── Find Fcitx5 KWin input-method plugin ─────────────────────────────────────
find_fcitx5_plugin() {
    # Check all known architecture-specific paths — no recursive find (too slow)
    local p
    for dir in \
        /usr/lib/x86_64-linux-gnu/qt6/plugins/kwin/inputmethods \
        /usr/lib64/qt6/plugins/kwin/inputmethods \
        /usr/lib/aarch64-linux-gnu/qt6/plugins/kwin/inputmethods \
        /usr/lib/arm-linux-gnueabihf/qt6/plugins/kwin/inputmethods \
        /usr/lib/x86_64-linux-gnu/plugins/kwin/inputmethods \
        /usr/lib64/plugins/kwin/inputmethods; do
        p="${dir}/fcitx5.so"
        [ -f "$p" ] && { echo "$p"; return; }
    done
    echo ""
}

# Standard Fcitx 5 desktop entry (KDE “Virtual keyboard → Fcitx 5”, NOT the experimental launcher).
# Using fcitx5-wayland-launcher.desktop leaves “Using Wayland native input method protocol: 0” in
# fcitx5 logs and breaks layout switching in many Wayland apps (e.g. browsers).
find_fcitx5_kwin_desktop() {
    local f
    for f in \
        /usr/share/applications/org.fcitx.Fcitx5.desktop \
        /usr/share/applications/fcitx5.desktop; do
        [ -f "$f" ] && { echo "$f"; return; }
    done
    echo ""
}

# Current KWin Wayland InputMethod= value (path to .desktop or .so), or empty.
read_kwin_inputmethod() {
    [ -f "$KWINRC" ] || return 0
    grep -iE '^InputMethod(\[.*\])?=' "$KWINRC" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '[:space:]'
}

is_kwin_wayland_launcher() {
    case "$(read_kwin_inputmethod)" in
        *fcitx5-wayland-launcher*) return 0 ;;
        *) return 1 ;;
    esac
}

# True when KWin is set up so fcitx5’s Wayland IM frontend can attach (KDE docs + fcitx5 self-diagnose).
kwin_wayland_im_ok() {
    local im plugin
    im="$(read_kwin_inputmethod)"
    plugin="$(find_fcitx5_plugin)"
    case "$im" in
        *fcitx5-wayland-launcher*) return 1 ;;
        "") return 1 ;;
    esac
    if [ -n "$plugin" ] && [ "$im" = "$plugin" ]; then
        return 0
    fi
    case "$im" in
        *org.fcitx.Fcitx5.desktop*|*fcitx5.desktop|*/fcitx5.so|*inputmethods/fcitx5.so*)
            return 0 ;;
        *)
            return 1 ;;
    esac
}

# ─── Read KDE keyboard layouts from kxkbrc ────────────────────────────────────
read_kde_layouts() {
    local list=""
    if command -v kreadconfig6 &>/dev/null; then
        list=$(kreadconfig6 --file kxkbrc --group Layout --key LayoutList 2>/dev/null || true)
    fi
    if [ -z "$list" ] && [ -f "$KXKBRC" ]; then
        list=$(grep '^LayoutList=' "$KXKBRC" | cut -d= -f2 | tr -d ' ' || true)
    fi
    if [ -z "$list" ]; then
        echo "us,ru"
        return
    fi

    # KDE typically stores ONLY the extra layouts; Latin/US is always the implicit base.
    # If no Latin layout is present, prepend "us" so Fcitx5 has both directions.
    local has_latin=false
    IFS=',' read -ra layouts <<< "$list"
    for l in "${layouts[@]}"; do
        case "$l" in
            us|gb|de|fr|es|it|pt|nl|pl|cz|sk|hu|ro|bg|sr|hr|sl|mk|tr|br|latam|dvorak|colemak)
                has_latin=true ;;
        esac
    done

    local merged
    if ! $has_latin; then
        merged="us,${list}"
    else
        merged="$list"
    fi
    # Status/setup must always show Punto’s us+ru (KDE often lists only “us” in LayoutList).
    ensure_ru_and_us_layouts "$merged"
}

# ─── Ensure Punto-relevant layouts ─────────────────────────────────────────
# We always need both EN (us) and RU (ru) for Punto-style ru<->en correction.
ensure_ru_and_us_layouts() {
    local layouts_csv="$1"
    layouts_csv="$(printf '%s' "$layouts_csv" | tr -d ' ')"

    # Preserve original order from KDE/XKB.
    # Only append missing layouts at the end.
    local has_us=0
    local has_ru=0
    IFS=',' read -ra arr <<< "$layouts_csv"
    for l in "${arr[@]}"; do
        case "$l" in
            us) has_us=1 ;;
            ru) has_ru=1 ;;
        esac
    done

    if [ "$has_us" -eq 0 ]; then
        layouts_csv="${layouts_csv},us"
    fi
    if [ "$has_ru" -eq 0 ]; then
        layouts_csv="${layouts_csv},ru"
    fi

    # Trim possible leading/trailing commas/spaces
    layouts_csv="$(printf '%s' "$layouts_csv" | sed 's/^,//; s/,$//')"
    echo "$layouts_csv"
}

# ─── XKB (kxkbrc) writer for XWayland fallback ─────────────────────────────
# When KWin fcitx5 virtual keyboard plugin is missing, browsers often run as
# XWayland clients. For them, global XKB state must include RU.

# KDE requires VariantList to have exactly one comma-separated slot per entry in LayoutList
# (empty slot = default XKB variant). If counts differ, System Settings shows only the first
# layout — “only English” even when LayoutList=us,ru.
build_variant_list_for_layouts() {
    local layouts_csv="$1"
    layouts_csv="$(printf '%s' "$layouts_csv" | tr -d ' ')"
    IFS=',' read -ra arr <<< "$layouts_csv"
    local n=${#arr[@]}
    [ "$n" -le 1 ] && { echo ""; return; }
    local i=0
    local out=""
    while [ "$i" -lt "$n" ]; do
        [ "$i" -gt 0 ] && out="${out},"
        i=$((i + 1))
    done
    echo "$out"
}

xkb_options_from_fcitx_switch_key() {
    local key="$1"

    case "$key" in
        *Alt+Shift_L*|*Shift+Alt_L*)           echo "grp:alt_shift_toggle" ;;
        *Ctrl+Shift_L*|*Control+Shift_L*|*Shift+Control_L*) echo "grp:ctrl_shift_toggle" ;;
        *Alt+Control_L*|*Alt+Ctrl_L*|*Ctrl+Alt_L*|*Control+Alt_L*) echo "grp:ctrl_alt_toggle" ;;
        *Control_L*|*Ctrl_L*)                 echo "grp:ctrl_toggle" ;;
        *Alt_L*)                               echo "grp:toggle" ;;
        *)
            echo "grp:ctrl_shift_toggle"
            ;;
    esac
}

write_kxkbrc_for_xwayland() {
    local layouts_csv="$1"
    local switch_key="$2"

    layouts_csv="$(printf '%s' "$layouts_csv" | tr -d ' ')"
    local kxkbrc="${HOME}/.config/kxkbrc"
    local xkb_options
    xkb_options="$(xkb_options_from_fcitx_switch_key "$switch_key")"
    # Always derive grp:* from the same switch key Fcitx5 uses — preserving old Options
    # often left grp:ctrl_toggle while the user switched to Ctrl+Shift (only English + broken toggle).

    local variant_list
    variant_list="$(build_variant_list_for_layouts "$layouts_csv")"

    mkdir -p "$(dirname "$kxkbrc")"

    # Friendly DisplayNames (not strictly required for switching).
    local display_names=""
    IFS=',' read -ra arr <<< "$layouts_csv"
    for l in "${arr[@]}"; do
        case "$l" in
            us|en|gb|uk)
                display_names="${display_names}English,"
                ;;
            ru)
                display_names="${display_names}Russian,"
                ;;
            *)
                display_names="${display_names}${l},"
                ;;
        esac
    done
    display_names="${display_names%,}"

    {
        echo "[Layout]"
        echo "DisplayNames=${display_names}"
        echo "LayoutList=${layouts_csv}"
        echo "Options=${xkb_options}"
        echo "Use=true"
        echo "VariantList=${variant_list}"
    } > "$kxkbrc"

    # Ensure KDE’s KConfig sees the same keys (some stacks only refresh after kwriteconfig6).
    if command -v kwriteconfig6 &>/dev/null; then
        kwriteconfig6 --file kxkbrc --group Layout --key LayoutList "$layouts_csv" 2>/dev/null || true
        kwriteconfig6 --file kxkbrc --group Layout --key DisplayNames "$display_names" 2>/dev/null || true
        kwriteconfig6 --file kxkbrc --group Layout --key VariantList "$variant_list" 2>/dev/null || true
        kwriteconfig6 --file kxkbrc --group Layout --key Options "$xkb_options" 2>/dev/null || true
        kwriteconfig6 --file kxkbrc --group Layout --key Use true 2>/dev/null || true
    fi

    if [ "${PUNTO_SWITCHER_SETUP_QUIET:-}" != "1" ]; then
        ok "kxkbrc written (KDE layouts + XKB; VariantList matches LayoutList; options: ${xkb_options})"
    fi
}

# Map Fcitx5 hotkey strings → KDE “Switch layout” display form (kglobalshortcutsrc).
fcitx5_key_to_kde_shortcut_string() {
    local k="$1"
    case "$k" in
        *Ctrl+Shift_L*|*Control+Shift_L*|*Shift+Control_L*) echo "Ctrl+Shift" ;;
        *Alt+Shift_L*|*Shift+Alt_L*) echo "Alt+Shift" ;;
        *Alt+Control_L*|*Alt+Ctrl*|*Ctrl+Alt*|*Control+Alt*|*Alt+Control*) echo "Ctrl+Alt" ;;
        Super+space|Super+Space) echo "Meta+Space" ;;
        Ctrl+Space) echo "Ctrl+Space" ;;
        *)
            printf '%s' "$k" | sed -e 's/Control_L/Ctrl/g' -e 's/Shift_L/Shift/g' -e 's/Alt_L/Alt/g' -e 's/Super_L/Meta/g' -e 's/Control\+/Ctrl+/g'
            ;;
    esac
}

# System Settings → Keyboard reads kxkbrc *and* kglobalshortcutsrc. Without the latter,
# “Переключение раскладки” shows «Не определена» even when Fcitx5 has a trigger key.
sync_kde_system_layout_switch_shortcut() {
    local fcitx_key="$1"
    command -v kwriteconfig6 &>/dev/null || return 0
    local kde_combo
    kde_combo="$(fcitx5_key_to_kde_shortcut_string "$fcitx_key")"
    [ -z "$kde_combo" ] && return 0

    mkdir -p "${HOME}/.config"
    # Format: primary,secondary,shortcut,Default (Plasma 5/6)
    local val="none,none,${kde_combo},Default"

    kwriteconfig6 --file kglobalshortcutsrc \
        --group "KDE Keyboard Layout Switcher" \
        --key "Switch to Next Keyboard Layout" \
        "$val" 2>/dev/null || true

    kwriteconfig6 --file kglobalshortcutsrc \
        --group "keyboard" \
        --key "Switch to Next Keyboard Layout" \
        "$val" 2>/dev/null || true

    if [ "${PUNTO_SWITCHER_SETUP_QUIET:-}" != "1" ]; then
        ok "KDE System Settings → Keyboard: layout switch shortcut set to ${kde_combo} (kglobalshortcutsrc)"
    fi
}

# Source of truth for post-login sync (KDE may reset kxkbrc / shortcuts to Meta+Alt+K or us-only).
read_fcitx5_trigger_key_from_config() {
    [ -f "$FCITX5_CONFIG" ] || { echo ""; return; }
    awk '/^\[Hotkey\/TriggerKeys\]/{f=1;next} f&&/^0=/{sub(/^0=/,""); print; exit} f&&/^\[/{exit}' "$FCITX5_CONFIG"
}

read_fcitx5_layouts_csv_from_profile() {
    [ -f "$FCITX5_PROFILE" ] || { echo ""; return; }
    grep '^Name=keyboard-' "$FCITX5_PROFILE" 2>/dev/null | sed 's/^Name=keyboard-//' | paste -sd,
}

# After session start Plasma/Fcitx sometimes overwrite KDE keyboard files — restore from Fcitx5.
cmd_sync_kde_keyboard() {
    local fk fl
    fk="$(read_fcitx5_trigger_key_from_config)"
    fl="$(read_fcitx5_layouts_csv_from_profile)"
    if [ -z "$fl" ]; then
        fl="$(ensure_ru_and_us_layouts "$(read_kde_layouts)")"
    else
        fl="$(ensure_ru_and_us_layouts "$fl")"
    fi
    [ -z "$fk" ] && fk="Ctrl+Space"
    if [ "${PUNTO_SWITCHER_SETUP_QUIET:-0}" = "1" ]; then
        PUNTO_SWITCHER_SETUP_QUIET=1 write_kxkbrc_for_xwayland "$fl" "$fk"
        PUNTO_SWITCHER_SETUP_QUIET=1 sync_kde_system_layout_switch_shortcut "$fk"
    else
        write_kxkbrc_for_xwayland "$fl" "$fk"
        sync_kde_system_layout_switch_shortcut "$fk"
    fi
}

install_kde_sync_autostart() {
    mkdir -p "$AUTOSTART_DIR"
    cat > "$AUTOSTART_KDE_SYNC" << 'EOF'
[Desktop Entry]
Type=Application
Name=Punto Switcher — KDE keyboard sync
Comment=Restore us+ru and layout shortcut from Fcitx5 after Plasma login
Exec=sh -c 'sleep 12; exec /usr/bin/env PUNTO_SWITCHER_SETUP_QUIET=1 /usr/bin/punto-switcher-setup --sync-kde-keyboard'
X-GNOME-Autostart-Delay=0
OnlyShowIn=KDE;
EOF
    ok "Installed login hook: ${AUTOSTART_KDE_SYNC} (fixes layout/shortcut reset after session start)"
}

remove_kde_sync_autostart() {
    if [ -f "$AUTOSTART_KDE_SYNC" ]; then
        rm -f "$AUTOSTART_KDE_SYNC"
        ok "Removed KDE sync autostart: ${AUTOSTART_KDE_SYNC}"
    fi
}

# Fcitx5 TriggerKeys must be a real combo (e.g. Ctrl+Space). A lone modifier breaks IM.
is_invalid_fcitx_switch_key() {
    local k="$1"
    [ -z "$k" ] && return 0
    case "$k" in
        Control_L|Control_R|Alt_L|Alt_R|Shift_L|Shift_R|Super_L|Super_R|Meta_L|Meta_R|Caps_Lock|Control|Ctrl|Alt|Shift|Super|Win|Meta)
            return 0 ;;
    esac
    return 1
}

# ─── Read KDE layout-switching shortcut ───────────────────────────────────────
# Returns a Fcitx5-compatible key string (e.g. "Ctrl+Shift_L", "Alt+Shift_L")
read_kde_switch_shortcut() {
    local raw=""

    # KDE Plasma 6: stored in [KDE Keyboard Layout Switcher] group
    if command -v kreadconfig6 &>/dev/null; then
        raw=$(kreadconfig6 --file kglobalshortcutsrc \
              --group "KDE Keyboard Layout Switcher" \
              --key "Switch to Next Keyboard Layout" 2>/dev/null || true)
    fi

    # Fallback: try old [keyboard] group (Plasma 5)
    if [ -z "$raw" ] || [ "$raw" = "none" ] && command -v kreadconfig6 &>/dev/null; then
        raw=$(kreadconfig6 --file kglobalshortcutsrc \
              --group "keyboard" \
              --key "Switch to Next Keyboard Layout" 2>/dev/null || true)
    fi

    # Also try reading directly from the file (more reliable for multi-value entries)
    if [ -z "$raw" ] && [ -f "${HOME}/.config/kglobalshortcutsrc" ]; then
        raw=$(grep -A20 '^\[KDE Keyboard Layout Switcher\]' \
              "${HOME}/.config/kglobalshortcutsrc" 2>/dev/null \
              | grep '^Switch to Next Keyboard Layout=' \
              | head -1 | cut -d= -f2-)
    fi

    # Value format: "primary,secondary,Alt+Shift,Default" (KDE) — never take a lone
    # "Shift" when "Alt+Shift" exists later, or Fcitx5 gets a useless trigger and only
    # some apps (e.g. one Electron build) appear to switch layouts.
    local shortcut=""
    local candidate=""
    IFS=',' read -ra parts <<< "$raw"
    for part in "${parts[@]}"; do
        part="${part// /}"   # strip spaces
        [ -z "$part" ] && continue
        [ "$part" = "none" ] && continue
        [ "$part" = "Default" ] && continue
        [[ "$part" == *"Description"* ]] && continue
        [[ "$part" =~ [а-яА-Я] ]] && continue
        [[ "$part" =~ \  ]] && continue
        # Prefer real combos (contains '+') over lone Shift/Alt/Control.
        if [[ "$part" == *+* ]]; then
            shortcut="$part"
            break
        fi
        [ -z "$candidate" ] && candidate="$part"
    done
    [ -z "$shortcut" ] && shortcut="$candidate"

    # If KDE string clearly contains Alt+Shift / Ctrl+Shift but we picked wrong token:
    if { is_invalid_fcitx_switch_key "$shortcut" || [ "$shortcut" = "Shift" ] || [ "$shortcut" = "Alt" ]; } \
        && [ -n "$raw" ]; then
        if echo "$raw" | grep -qE 'Alt\+Shift|Shift\+Alt'; then
            shortcut="Alt+Shift"
        elif echo "$raw" | grep -qE 'Ctrl\+Shift|Shift\+Ctrl|Control\+Shift|Shift\+Control'; then
            shortcut="Ctrl+Shift"
        fi
    fi

    [ -z "$shortcut" ] && { echo ""; return; }

    # Normalize common KDE spellings → Fcitx5 (case-insensitive)
    local sl="${shortcut,,}"
    case "$sl" in
        alt+shift|shift+alt) shortcut="Alt+Shift" ;;
        ctrl+shift|shift+ctrl|control+shift|shift+control) shortcut="Ctrl+Shift" ;;
        alt+ctrl|ctrl+alt|control+alt|alt+control) shortcut="Alt+Ctrl" ;;
    esac

    # Convert KDE/xkb modifier names → Fcitx5 key names
    local out=""
    case "$shortcut" in
        # Never map to a lone *_L — Fcitx5 cannot use that as Enumerate trigger.
        "Control"|"Ctrl"|"Alt"|"Shift"|"Super"|"Win"|"Meta"|"Caps_Lock"|"CapsLock") out="" ;;
        "Alt+Shift"|"Shift+Alt")     out="Alt+Shift_L" ;;
        "Ctrl+Shift"|"Shift+Ctrl")   out="Ctrl+Shift_L" ;;
        "Alt+Ctrl"|"Ctrl+Alt"|"Alt+Control"|"Control+Alt") out="Alt+Control_L" ;;
        "Win+Space"|"Meta+Space"|"Super+Space") out="Super+space" ;;
        *)
            out="$shortcut"
            ;;
    esac
    if is_invalid_fcitx_switch_key "$out"; then
        out=""
    fi
    echo "$out"
}

# ─── Check whether the Fcitx5 profile already has a given layout ──────────────
profile_has_layout() {
    local layout="$1"
    [ -f "$FCITX5_PROFILE" ] || return 1
    grep -q "^Name=keyboard-${layout}$" "$FCITX5_PROFILE"
}

# ─── Write / update Fcitx5 profile ────────────────────────────────────────────
write_fcitx5_profile() {
    local layouts_csv="$1"
    IFS=',' read -ra layouts <<< "$layouts_csv"

    # If profile already exists, merge: add only missing layouts
    local existing_count=0
    if [ -f "$FCITX5_PROFILE" ]; then
        existing_count=$(grep -c '^Name=keyboard-' "$FCITX5_PROFILE" 2>/dev/null || echo 0)
        # Backup
        cp "$FCITX5_PROFILE" "${FCITX5_PROFILE}.bak.$(date +%Y%m%d%H%M%S)"
        info "Backed up existing Fcitx5 profile → ${FCITX5_PROFILE}.bak.*"
    fi

    # Re-generate from scratch (simpler and safer than incremental patching)
    # Preserve user's previous default layout when possible.
    local first_layout="${layouts[0]}"
    if [ -f "$FCITX5_PROFILE" ]; then
        local old_default
        old_default="$(grep '^Default Layout=' "$FCITX5_PROFILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d ' ')"
        if [ -n "$old_default" ]; then
            local keep=0
            for l in "${layouts[@]}"; do
                if [ "$l" = "$old_default" ]; then keep=1; break; fi
            done
            if [ "$keep" -eq 1 ]; then
                first_layout="$old_default"
            fi
        fi
    fi
    {
        echo "[Groups/0]"
        echo "# Group Name"
        echo "Name=Default"
        echo "# Default Layout"
        echo "Default Layout=${first_layout}"
        echo "# Default Input Method"
        echo "DefaultIM=keyboard-${first_layout}"
        echo ""
        local idx=0
        for layout in "${layouts[@]}"; do
            [ -z "$layout" ] && continue
            echo "[Groups/0/Items/${idx}]"
            echo "# Name"
            echo "Name=keyboard-${layout}"
            echo "# Layout"
            echo "Layout="
            echo ""
            (( idx++ )) || true
        done
        echo "[GroupOrder]"
        echo "0=Default"
    } > "$FCITX5_PROFILE"
    ok "Fcitx5 profile written (${#layouts[@]} layout(s): ${layouts[*]})"
}

# ─── Write Fcitx5 global config (hotkeys for layout switching) ────────────────
write_fcitx5_config() {
    local switch_key="$1"

    # Hard conflict guard:
    # KDE/Fcitx5 layout switching must not steal Punto swap keys:
    #   Alt+' / Alt+Shift+'
    # If conflict detected, force a safe layout-switch binding.
    local switch_key_l
    switch_key_l="$(printf '%s' "$switch_key" | tr 'A-Z' 'a-z')"
    case "$switch_key_l" in
        *alt+apostrophe*|*alt+quotedbl*|*alt+grave*|*alt+shift+apostrophe*|*alt+shift+quotedbl*|*alt+shift+grave*)
            switch_key="Ctrl+Space"
            ;;
    esac

    mkdir -p "$(dirname "$FCITX5_CONFIG")"

    # Important: do NOT overwrite the entire fcitx5 config — it may contain
    # additional settings required for syncing layouts for XWayland/browser
    # clients. We rewrite only the Hotkey-related sections.
    local tmp="${FCITX5_CONFIG}.tmp.$RANDOM"

    if [ -f "$FCITX5_CONFIG" ]; then
        awk '
            BEGIN{skip=0}
            {
                if ($0 ~ /^\[Hotkey\]$/) {skip=1; next}
                if ($0 ~ /^\[Hotkey\/(TriggerKeys|EnumerateForwardKeys|EnumerateBackwardKeys|ActivateKeys|DeactivateKeys)\]/) {skip=1; next}
                if ($0 ~ /^\[/ && skip==1) {skip=0}
                if (skip==1) next
                print
            }
        ' "$FCITX5_CONFIG" > "$tmp"
    else
        : > "$tmp"
    fi

    {
        cat "$tmp"
        echo ""
        echo "[Hotkey]"
        echo "# Enumerate Input Method in group"
        echo "EnumerateWithTriggerKeys=True"
        echo "EnumerateSkipFirst=False"
        echo ""
        echo "[Hotkey/TriggerKeys]"
        if [ -n "$switch_key" ]; then
            echo "0=${switch_key}"
        else
            echo "0=Ctrl+Space"
        fi
        echo ""
        echo "[Hotkey/EnumerateForwardKeys]"
        if [ -n "$switch_key" ]; then
            echo "0=${switch_key}"
        else
            echo "0=Ctrl+Shift+space"
        fi
        echo ""
        echo "[Hotkey/EnumerateBackwardKeys]"
        echo "0="
        echo ""
        echo "[Hotkey/ActivateKeys]"
        echo "0=Hangul"
        echo ""
        echo "[Hotkey/DeactivateKeys]"
        echo "0=Hangul_Romaja"
    } > "$FCITX5_CONFIG"

    rm -f "$tmp" 2>/dev/null || true
    ok "Fcitx5 config hotkeys updated (switch key: ${switch_key:-Ctrl+Space})"
}

# ─── Set Fcitx5 as KWin virtual keyboard (plugin-based, Plasma 5 / early P6) ──
set_kwin_virtual_keyboard() {
    local plugin="$1"
    [ -z "$plugin" ] && { warn "Plugin path empty — skipping KWin VK setup"; return 1; }

    kwriteconfig6 --file kwinrc --group Wayland --key InputMethod "$plugin"
    ok "Set KWin virtual keyboard → ${plugin}"

    if command -v qdbus6 &>/dev/null; then
        qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null \
            && ok "KWin configuration reloaded" \
            || warn "KWin reconfigure failed (may need logout/login)"
    fi
}

# ─── Remove Fcitx5 as KWin virtual keyboard (undo) ───────────────────────────
unset_kwin_virtual_keyboard() {
    kwriteconfig6 --file kwinrc --group Wayland --key InputMethod ""
    ok "KWin virtual keyboard cleared"
    if command -v qdbus6 &>/dev/null; then
        qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null || true
    fi
}

# ─── Set up Fcitx5 via environment variables (universal Wayland fallback) ─────
# Works for Qt5, Qt6, GTK3, GTK4 apps without requiring a KWin plugin.
# Plasma reads files from ~/.config/plasma-workspace/env/ on session start.
# systemd user session reads ~/.config/environment.d/*.conf — often required so
# GTK_IM_MODULE reaches browsers started from systemd/D-Bus (not only Plasma).
setup_env_vars() {
    local envdir="${HOME}/.config/plasma-workspace/env"
    local envfile="${envdir}/fcitx5-im.sh"
    mkdir -p "$envdir"
    cat > "$envfile" << 'EOF'
# Fcitx5 input method environment — written by punto-switcher-setup
export INPUT_METHOD=fcitx5
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS="@im=fcitx"
export MOZ_ENABLE_WAYLAND=1
EOF
    chmod +x "$envfile"
    ok "Written Plasma env: ${envfile}"

    # systemd --user: picked up on next login (and by many GUI services)
    local envd="${HOME}/.config/environment.d"
    mkdir -p "$envd"
    cat > "${envd}/fcitx5-im.conf" << 'EOF'
# Fcitx5 — written by punto-switcher-setup (systemd user environment.d)
INPUT_METHOD=fcitx5
GTK_IM_MODULE=fcitx
QT_IM_MODULE=fcitx
XMODIFIERS=@im=fcitx
MOZ_ENABLE_WAYLAND=1
EOF
    ok "Written systemd user env: ${envd}/fcitx5-im.conf"

    if command -v systemctl &>/dev/null && systemctl --user status >/dev/null 2>&1; then
        systemctl --user daemon-reload 2>/dev/null || true
        systemctl --user import-environment INPUT_METHOD GTK_IM_MODULE QT_IM_MODULE XMODIFIERS MOZ_ENABLE_WAYLAND 2>/dev/null || true
    fi
}

# Flatpak browsers run in a sandbox and ignore host ~/.profile / Plasma env unless overridden.
setup_flatpak_im_overrides() {
    command -v flatpak &>/dev/null || return 0
    local ref
    local applied=0
    for ref in \
        org.mozilla.firefox \
        org.mozilla.firefox_beta \
        com.google.Chrome \
        org.chromium.Chromium \
        com.brave.Browser \
        com.microsoft.Edge \
        com.vivaldi.Vivaldi; do
        flatpak info "$ref" &>/dev/null || continue
        if flatpak override --user \
            --env=INPUT_METHOD=fcitx5 \
            --env=GTK_IM_MODULE=fcitx \
            --env=QT_IM_MODULE=fcitx \
            --env=XMODIFIERS=@im=fcitx \
            --env=MOZ_ENABLE_WAYLAND=1 \
            "$ref" 2>/dev/null; then
            ok "Flatpak IM env: ${ref}"
            applied=1
        fi
    done
    [ "$applied" -eq 0 ] && info "No Flatpak browsers detected (or override skipped)."
}

remove_env_vars() {
    local envfile="${HOME}/.config/plasma-workspace/env/fcitx5-im.sh"
    if [ -f "$envfile" ]; then
        rm -f "$envfile"
        ok "Removed Plasma env file: ${envfile}"
    fi
    local envd="${HOME}/.config/environment.d/fcitx5-im.conf"
    if [ -f "$envd" ]; then
        rm -f "$envd"
        ok "Removed systemd env.d: ${envd}"
    fi
}

# ─── Check whether env vars are configured ────────────────────────────────────
has_env_vars() {
    local envfile="${HOME}/.config/plasma-workspace/env/fcitx5-im.sh"
    [ -f "$envfile" ] && grep -q "fcitx" "$envfile"
}

has_systemd_env_d() {
    local f="${HOME}/.config/environment.d/fcitx5-im.conf"
    [ -f "$f" ] && grep -q "fcitx" "$f"
}

# GTK_IM_MODULE seen by a running process (Linux)
read_proc_env_gtk_im() {
    local pid="$1"
    [ -r "/proc/${pid}/environ" ] || return 1
    tr '\0' '\n' < "/proc/${pid}/environ" | grep '^GTK_IM_MODULE=' | head -1 | cut -d= -f2-
}

# Report whether common browser processes have GTK_IM_MODULE=fcitx
status_browser_im() {
    local name pid gtk shown=0
    # Binary names (first match per name)
    for name in firefox firefox-esr thunderbird chromium chromium-browser \
                google-chrome chrome brave brave-browser vivaldi-stable vivaldi opera; do
        pid=$(pgrep -nx "$name" 2>/dev/null) || continue
        gtk="$(read_proc_env_gtk_im "$pid")"
        shown=1
        if [ "$gtk" = "fcitx" ]; then
            echo -e "  Browser ${name}[$pid] GTK_IM: ${GREEN}fcitx ✓${RESET}"
        elif [ -z "$gtk" ]; then
            echo -e "  Browser ${name}[$pid] GTK_IM: ${YELLOW}unset${RESET} — ${CYAN}quit browser, log out/in, reopen${RESET}"
        else
            echo -e "  Browser ${name}[$pid] GTK_IM: ${RED}${gtk}${RESET} — ${CYAN}relogin or Flatpak override${RESET}"
        fi
    done
    [ "$shown" -eq 0 ] && echo -e "  Browser processes:     ${CYAN}none running${RESET} (start Firefox/Chromium and re-run --status)"
}

status_snap_hint() {
    command -v snap &>/dev/null || return 0
    snap list firefox chromium 2>/dev/null | grep -q . || return 0
    echo -e "  ${YELLOW}Snap browser detected:${RESET} host GTK_IM may not apply. Prefer distro/Flatpak build or see snap forum for IM."
}

# ─── Remove the first-run autostart entry ─────────────────────────────────────
remove_autostart() {
    if [ -f "$AUTOSTART_ENTRY" ]; then
        rm -f "$AUTOSTART_ENTRY"
        ok "Removed first-run autostart entry"
    fi
}

# ─── Start / restart Fcitx5 ──────────────────────────────────────────────────
restart_fcitx5() {
    # Kill ALL existing instances to avoid D-Bus name conflicts
    if pgrep -x fcitx5 >/dev/null 2>&1; then
        info "Stopping all Fcitx5 instances..."
        pkill -x fcitx5 2>/dev/null || true
        # Wait until all instances are gone (up to 3 seconds)
        for i in 1 2 3; do
            sleep 1
            pgrep -x fcitx5 >/dev/null 2>&1 || break
        done
        pkill -9 -x fcitx5 2>/dev/null || true
        sleep 0.5
    fi
    info "Starting Fcitx5..."
    fcitx5 -d 2>/dev/null && ok "Fcitx5 started" || warn "Could not start Fcitx5 (try manually: fcitx5 -d)"
}

# ─── STATUS command ───────────────────────────────────────────────────────────
cmd_status() {
    echo -e "\n${BOLD}Punto Switcher — Setup Status${RESET}"
    echo "───────────────────────────────────────"

    # 1. KDE layouts
    local layouts
    layouts=$(read_kde_layouts)
    echo -e "  KDE keyboard layouts:  ${CYAN}${layouts}${RESET}"

    # 2. Fcitx5 profile
    if [ -f "$FCITX5_PROFILE" ]; then
        local im_count
        im_count=$(grep -c '^Name=keyboard-' "$FCITX5_PROFILE" 2>/dev/null || echo 0)
        echo -e "  Fcitx5 profile:        ${GREEN}present${RESET} (${im_count} layout(s))"
    else
        echo -e "  Fcitx5 profile:        ${RED}missing${RESET}"
    fi

    # 3. Env vars (Plasma session + systemd user — browsers need both paths)
    if has_env_vars; then
        echo -e "  IM env (Plasma):       ${GREEN}configured ✓${RESET} (~/.config/plasma-workspace/env/)"
    else
        echo -e "  IM env (Plasma):       ${YELLOW}not set${RESET}"
    fi
    if has_systemd_env_d; then
        echo -e "  IM env (systemd user): ${GREEN}configured ✓${RESET} (~/.config/environment.d/)"
    else
        echo -e "  IM env (systemd user): ${YELLOW}missing${RESET} — run ${CYAN}punto-switcher-setup${RESET}"
    fi

    if [ -f "$AUTOSTART_KDE_SYNC" ]; then
        echo -e "  KDE post-login sync: ${GREEN}enabled ✓${RESET} (~/.config/autostart/punto-switcher-kde-sync.desktop)"
    else
        echo -e "  KDE post-login sync: ${YELLOW}off${RESET} — run ${CYAN}punto-switcher-setup${RESET} to restore us+ru after login"
    fi

    # 4. KWin virtual keyboard (fcitx5.so plugin OR org.fcitx.Fcitx5.desktop — NOT Wayland Launcher)
    local plugin im
    plugin=$(find_fcitx5_plugin)
    im="$(read_kwin_inputmethod)"
    if [ -n "$plugin" ]; then
        if [ "$im" = "$plugin" ] || [[ "$im" == *fcitx5.so ]]; then
            echo -e "  KWin virtual keyboard: ${GREEN}fcitx5.so ✓${RESET} (plugin)"
        else
            echo -e "  KWin virtual keyboard: ${YELLOW}fcitx5.so present but not selected in kwinrc${RESET}"
        fi
    else
        if is_kwin_wayland_launcher; then
            echo -e "  KWin virtual keyboard: ${RED}Fcitx 5 Wayland Launcher${RESET} — ${YELLOW}breaks layout in browsers${RESET}"
            echo -e "                           ${CYAN}Run punto-switcher-setup${RESET} to use ${GREEN}Fcitx 5${RESET} (see journal: Wayland native IM protocol must be 1)"
        elif kwin_wayland_im_ok; then
            echo -e "  KWin virtual keyboard: ${GREEN}Fcitx 5 ✓${RESET} (desktop entry — Wayland IM)"
        else
            echo -e "  KWin virtual keyboard: ${YELLOW}not set to Fcitx 5${RESET} — run ${CYAN}punto-switcher-setup${RESET}"
        fi
    fi

    # 5. Fcitx5 running?
    if pgrep -x fcitx5 >/dev/null 2>&1; then
        echo -e "  Fcitx5 running:        ${GREEN}yes${RESET}"
    else
        echo -e "  Fcitx5 running:        ${RED}no${RESET}"
    fi

    # 6. Running browsers: do they actually see GTK_IM_MODULE=fcitx?
    echo ""
    status_browser_im
    status_snap_hint

    # Summary
    echo ""
    if [ -f "$FCITX5_PROFILE" ] && has_env_vars && has_systemd_env_d && pgrep -x fcitx5 >/dev/null 2>&1; then
        if kwin_wayland_im_ok; then
            echo -e "  ${GREEN}${BOLD}✓ Config looks complete — if browser still wrong: quit browser, log out/in, check lines above${RESET}"
        else
            echo -e "  ${YELLOW}${BOLD}⚠ IM env OK, but KWin is not using Fcitx 5 VK — run: punto-switcher-setup${RESET}"
        fi
    elif [ -f "$FCITX5_PROFILE" ] && kwin_wayland_im_ok && pgrep -x fcitx5 >/dev/null 2>&1; then
        echo -e "  ${GREEN}${BOLD}✓ KWin VK OK — run punto-switcher-setup to refresh Plasma + systemd IM env${RESET}"
    else
        echo -e "  ${YELLOW}Setup incomplete — run: punto-switcher-setup${RESET}"
    fi
    echo ""
}

# ─── UNDO command ─────────────────────────────────────────────────────────────
cmd_undo() {
    echo -e "\n${BOLD}Punto Switcher — Undo Setup${RESET}"
    echo "───────────────────────────────────────"
    unset_kwin_virtual_keyboard
    remove_env_vars
    remove_autostart
    remove_kde_sync_autostart
    echo ""
    echo -e "${YELLOW}Undo complete. Log out and back in to restore your original keyboard.${RESET}"
    echo "Punto Switcher will stop working until you run setup again."
}

# ─── MAIN SETUP ───────────────────────────────────────────────────────────────
cmd_setup() {
    echo -e "\n${BOLD}Punto Switcher — First-Time Setup${RESET}"
    echo "───────────────────────────────────────"
    echo "This will migrate your KDE keyboard layouts to Fcitx5"
    echo "so that Punto Switcher can intercept and correct keystrokes."
    echo "Your existing layouts and shortcuts are preserved."
    echo ""

    # ---- 1. Detect KDE layouts ----
    local kde_layouts
    kde_layouts=$(read_kde_layouts)
    kde_layouts="$(ensure_ru_and_us_layouts "$kde_layouts")"

    # Preserve user's previous default layout ordering for initial group.
    if [ -f "$FCITX5_PROFILE" ]; then
        local old_default
        old_default="$(grep '^Default Layout=' "$FCITX5_PROFILE" 2>/dev/null | head -1 | cut -d= -f2- | tr -d ' ')"
        if [ -n "$old_default" ]; then
            # Reorder layouts so that old_default becomes the first element.
            local reordered=""
            local found=0
            IFS=',' read -ra tmp <<< "$kde_layouts"
            for l in "${tmp[@]}"; do
                if [ "$l" = "$old_default" ]; then
                    reordered="$reordered$l"
                    found=1
                    break
                fi
            done
            for l in "${tmp[@]}"; do
                if [ "$l" = "$old_default" ]; then continue; fi
                if [ -z "$reordered" ]; then
                    reordered="$l"
                else
                    reordered="${reordered},$l"
                fi
            done
            if [ "$found" -eq 1 ]; then
                kde_layouts="$reordered"
            fi
        fi
    fi
    info "Detected KDE layouts: ${kde_layouts}"

    # ---- 2. Find KWin plugin ----
    local plugin
    plugin=$(find_fcitx5_plugin)
    if [ -z "$plugin" ]; then
        info "KWin fcitx5.so plugin not installed (many distros omit it). Using org.fcitx.Fcitx5.desktop for KWin instead."
        echo ""
    fi

    # ---- 3. Create Fcitx5 directory ----
    mkdir -p "$FCITX5_DIR"

    # ---- 4. Write Fcitx5 profile ----
    write_fcitx5_profile "$kde_layouts"

    # ---- 5. Write Fcitx5 config (switching shortcut) ----
    local kde_shortcut fcitx5_key
    kde_shortcut=$(read_kde_switch_shortcut)
    fcitx5_key="$kde_shortcut"
    if [ -z "$fcitx5_key" ] || is_invalid_fcitx_switch_key "$fcitx5_key"; then
        fcitx5_key="Ctrl+Space"
        info "KDE layout shortcut missing or invalid for Fcitx5 (was: ${kde_shortcut:-empty}); using Ctrl+Space"
    else
        info "Using your KDE switching shortcut: ${kde_shortcut} → ${fcitx5_key}"
    fi

    # Avoid hotkey conflicts with Punto swap keys:
    #   Alt+'            = swap last word (Punto)
    #   Alt+Shift+'     = swap selection / delete+replace (Punto)
    # If KDE/Fcitx5 layout switching uses Alt+' it steals the key combo and
    # Punto won't receive it reliably.
    fcitx5_key_l="$(printf '%s' "$fcitx5_key" | tr 'A-Z' 'a-z')"
    case "$fcitx5_key_l" in
        *alt+apostrophe*|*alt+quotedbl*|*alt+grave*|*alt+shift+apostrophe*|*alt+shift+quotedbl*|*alt+shift+grave*)
            info "Detected layout-switch hotkey conflicts with Punto. Using Ctrl+Space instead: ${fcitx5_key} → Ctrl+Space"
            fcitx5_key="Ctrl+Space"
            ;;
    esac
    write_fcitx5_config "$fcitx5_key"

    # ---- 6. Set up input method integration ----
    local fcitx_desktop
    fcitx_desktop="$(find_fcitx5_kwin_desktop)"
    if [ -n "$plugin" ]; then
        set_kwin_virtual_keyboard "$plugin"
    else
        # Without fcitx5.so, KWin must use org.fcitx.Fcitx5.desktop — NOT fcitx5-wayland-launcher.desktop —
        # or fcitx5 stays at “Using Wayland native input method protocol: 0” and browsers mis-handle layouts.
        if [ -n "$fcitx_desktop" ]; then
            set_kwin_virtual_keyboard "$fcitx_desktop"
        else
            warn "Could not find org.fcitx.Fcitx5.desktop — is the fcitx5 package installed?"
        fi
    fi
    # Always: GTK/Qt IM env (Plasma + systemd env.d) — required for browsers even when KWin plugin exists.
    setup_env_vars
    setup_flatpak_im_overrides
    write_kxkbrc_for_xwayland "$kde_layouts" "$fcitx5_key"
    # Same shortcut in KDE’s own config so System Settings → Keyboard shows layouts + combo (not only Fcitx5).
    sync_kde_system_layout_switch_shortcut "$fcitx5_key"
    info "Reopen System Settings → Keyboard to verify us+ru and the shortcut; log out/in if the layout list is still stale."

    # ---- 7. Start/restart Fcitx5 ----
    restart_fcitx5

    # ---- 8. Remove first-run autostart; install KDE post-login sync (Plasma resets kxkbrc) ----
    remove_autostart
    install_kde_sync_autostart

    echo ""
    echo -e "${GREEN}${BOLD}Setup complete!${RESET}"
    echo ""
    echo "  Layouts active in Fcitx5: $(echo "$kde_layouts" | tr ',' '  ')"
    echo "  Switch layouts with:      ${fcitx5_key}"
    echo "  Punto swap last word:     Alt+'"
    echo "  Punto swap selection:     Alt+Shift+'"
    echo ""

    if ! has_env_vars && ! kwin_wayland_im_ok; then
        echo -e "${YELLOW}WARNING:${RESET} Neither IM env vars nor KWin Fcitx 5 virtual keyboard is configured."
        echo "  Re-run this script or set: System Settings → Virtual Keyboard → ${BOLD}Fcitx 5${RESET} (not Wayland Launcher)."
        echo ""
    else
        echo -e "${YELLOW}ACTION REQUIRED:${RESET}"
        echo "  • Log out and back in (or reboot) so Plasma + systemd pick up IM environment."
        echo "  • Fully quit the browser, then reopen — or run ${CYAN}punto-switcher-setup --status${RESET} and check GTK_IM for your browser."
        echo ""
    fi
}

# ─── Entry point ──────────────────────────────────────────────────────────────
case "${1:-}" in
    --status|-s) cmd_status ;;
    --undo|-u)   cmd_undo ;;
    --sync-kde-keyboard) cmd_sync_kde_keyboard ;;
    --help|-h)
        echo "Usage: $0 [--status | --undo | --sync-kde-keyboard | --help]"
        echo ""
        echo "  (no args)             Run full setup: migrate layouts, configure virtual keyboard"
        echo "  --status              Show current setup state without making changes"
        echo "  --undo                Remove Fcitx5 as virtual keyboard, restore KDE native"
        echo "  --sync-kde-keyboard   Re-apply KDE kxkbrc + shortcuts from Fcitx5 (after login)"
        exit 0
        ;;
    "")          cmd_setup ;;
    *)
        err "Unknown option: $1"
        echo "Run '$0 --help' for usage."
        exit 1
        ;;
esac
